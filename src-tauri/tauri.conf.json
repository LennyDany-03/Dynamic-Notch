{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "windows_dynamic_noich",
  "version": "0.1.0",
  "identifier": "com.lenny.windows_dynamic_noich",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "notch-widget",
        "title": "",
        "width": 560,
        "height": 420,
        "minWidth": 560,
        "minHeight": 420,
        "maxWidth": 560,
        "maxHeight": 420,
        "y": 0,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "shadow": false,
        "visible": true,
        "focus": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
